# Configuración del pipeline. Copia este archivo a .env y completa los valores.
#   cp .env.example .env
# Las credenciales de GCP NO van aquí: usar `gcloud auth application-default login`.

GCP_PROJECT_ID=tu-project-id
GCS_BUCKET=tu-bucket
BQ_DATASET_RAW=raw
BQ_DATASET_STAGE=stage
BQ_DATASET_ANALYTICS=analytics
DATA_DIR=data_raw
